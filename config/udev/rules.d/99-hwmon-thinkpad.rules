# Stable symlinks for hwmon devices
# Auto-generated by setup-hwmon-udev.sh for ThinkPad T14s Gen 5
#
# This creates stable device names like /dev/hwmon-coretemp
# that won't change between reboots
#
# Installation:
#   sudo cp 99-hwmon-thinkpad.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger --subsystem-match=hwmon
#
# Verification:
#   ls -l /dev/hwmon-*

# CPU temperature sensors (coretemp)
SUBSYSTEM=="hwmon", ATTR{name}=="coretemp", SYMLINK+="hwmon-coretemp"

# ThinkPad embedded controller sensors
SUBSYSTEM=="hwmon", ATTR{name}=="thinkpad", SYMLINK+="hwmon-thinkpad"

# NVME drive 0
SUBSYSTEM=="hwmon", DEVPATH=="*/nvme/nvme0/*", SYMLINK+="hwmon-nvme0"

# WiFi adapter (iwlwifi)
SUBSYSTEM=="hwmon", ATTR{name}=="iwlwifi_1", SYMLINK+="hwmon-wifi"

# ACPI thermal zone
SUBSYSTEM=="hwmon", ATTR{name}=="acpitz", SYMLINK+="hwmon-acpitz"

# Battery
SUBSYSTEM=="hwmon", ATTR{name}=="BAT0", SYMLINK+="hwmon-BAT0"

# AC Adapter
SUBSYSTEM=="hwmon", ATTR{name}=="AC", SYMLINK+="hwmon-AC"

# USB-C power supply 1
SUBSYSTEM=="hwmon", ATTR{name}=="ucsi_source_psy_USBC000:001", SYMLINK+="hwmon-usbc1"

# USB-C power supply 2
SUBSYSTEM=="hwmon", ATTR{name}=="ucsi_source_psy_USBC000:002", SYMLINK+="hwmon-usbc2"
