#
# PERFORMANCE:
# ------------
# disableCef=true                           - Disable CEF/webview (CURRENTLY ENABLED)
# enableAlphaBuffer=true                    - Enable alpha buffer
# enableGPUEnhancement=true                 - Enable GPU enhancement
#
# LOGGING:
# --------
# enableLog=false                           - Enable logging (CONFIGURABLE via -l flag)
# logLevel=info                             - Logging level (info/debug/error)
