#!/bin/bash
################################################################################
# Zoom Linux Configuration Script
#
# This script configures Zoom settings programmatically on Linux systems.
# It disables the mini window feature and sets other UI preferences.
#
# PREREQUISITES:
#   - crudini: INI file manipulation tool
#     Install on Ubuntu/Debian: sudo apt-get install crudini
#     Install on Fedora/RHEL:   sudo dnf install crudini
#     Install on Arch:          sudo pacman -S crudini
#
# USAGE:
#   ./configure-zoom.sh [OPTIONS]
#
# OPTIONS:
#   -l    Enable logging (disabled by default)
#         Logs saved to: ~/.zoom/logs/
#   -h    Show this help message
#
# NOTE:
#   - Zoom must be restarted for changes to take effect
#   - Config file location: ~/.config/zoomus.conf
#   - For Flatpak: ~/.var/app/us.zoom.Zoom/config/zoomus.conf
#
# REFERENCES:
#   Configuration options documented from:
#   - https://gist.github.com/wallentx/4c75a2c10fd0c46f696548d9d23382d2
#   - https://wiki.archlinux.org/title/Zoom_Meetings
#   - https://support.zoom.com/hc/en/article?id=zm_kb&sysparm_article=KB0066626
################################################################################

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration file path
ZOOM_CONFIG="${HOME}/.config/zoomus.conf"

# Default options
ENABLE_LOGGING=false

# Show usage
usage() {
    cat << EOF
Zoom Linux Configuration Script

USAGE:
    $0 [OPTIONS]

OPTIONS:
    -l    Enable logging (disabled by default)
          Logs saved to: ~/.zoom/logs/
    -h    Show this help message

EXAMPLE:
    $0         # Configure without logging
    $0 -l      # Configure with logging enabled

EOF
    exit 0
}

# Parse command line options
while getopts "lh" opt; do
    case $opt in
        l)
            ENABLE_LOGGING=true
            ;;
        h)
            usage
            ;;
        \?)
            echo -e "${RED}Invalid option: -$OPTARG${NC}" >&2
            echo "Use -h for help"
            exit 1
            ;;
    esac
done

# Check if crudini is installed
if ! command -v crudini &> /dev/null; then
    echo -e "${RED}Error: crudini is not installed${NC}"
    echo "Please install crudini first:"
    echo "  Ubuntu/Debian: sudo apt-get install crudini"
    echo "  Fedora/RHEL:   sudo dnf install crudini"
    echo "  Arch:          sudo pacman -S crudini"
    exit 1
fi

# Create config directory if it doesn't exist
mkdir -p "$(dirname "$ZOOM_CONFIG")"

# Create config file if it doesn't exist
if [ ! -f "$ZOOM_CONFIG" ]; then
    echo -e "${YELLOW}Config file not found. Creating new file...${NC}"
    echo "[General]" > "$ZOOM_CONFIG"
fi

echo "Configuring Zoom settings in: $ZOOM_CONFIG"
echo "----------------------------------------"

# =============================================================================
# MEETING CONTROLS
# =============================================================================

# Disable mini window overlay
echo "Setting enableMiniWindow=false"
crudini --set "$ZOOM_CONFIG" General enableMiniWindow false

# Always show meeting controls
echo "Setting alwaysShowMeetingControls=true"
crudini --set "$ZOOM_CONFIG" General alwaysShowMeetingControls true

# =============================================================================
# AUDIO SETTINGS
# =============================================================================

# Auto-join with computer audio
echo "Setting zAutoJoinVoip=true"
crudini --set "$ZOOM_CONFIG" General zAutoJoinVoip true

# Start muted when joining
echo "Setting MuteVoipWhenJoin=true"
crudini --set "$ZOOM_CONFIG" General MuteVoipWhenJoin true

# =============================================================================
# VIDEO SETTINGS
# =============================================================================

# Capture HD camera
echo "Setting captureHDCamera=true"
crudini --set "$ZOOM_CONFIG" General captureHDCamera true

# Start meetings with video enabled
echo "Setting newMeetingWithVideo=true"
crudini --set "$ZOOM_CONFIG" General newMeetingWithVideo true

# Hide non-video participants
echo "Setting zHideNoVideoUser=true"
crudini --set "$ZOOM_CONFIG" General zHideNoVideoUser true

# =============================================================================
# SCREEN SHARING & REMOTE CONTROL
# =============================================================================

# Enable Do Not Disturb during screen sharing
echo "Setting EnableDoNotDisturbInSharing=true"
crudini --set "$ZOOM_CONFIG" General EnableDoNotDisturbInSharing true

# Disable remote control for security
echo "Setting DisableRemoteControl=true"
crudini --set "$ZOOM_CONFIG" General DisableRemoteControl true

# Disable remote support feature
echo "Setting DisableRemoteSupport=true"
crudini --set "$ZOOM_CONFIG" General DisableRemoteSupport true

# =============================================================================
# UPDATES
# =============================================================================

# Disable user-initiated updates
echo "Setting zAutoUpdate=false"
crudini --set "$ZOOM_CONFIG" General zAutoUpdate false

# Disable update version checking
echo "Setting AlwaysCheckLatestVersion=false"
crudini --set "$ZOOM_CONFIG" General AlwaysCheckLatestVersion false

# Disable silent auto-updates
echo "Setting EnableSilentAutoUpdate=false"
crudini --set "$ZOOM_CONFIG" General EnableSilentAutoUpdate false

# =============================================================================
# INTEGRATIONS
# =============================================================================

# Disable Zoom Apps (third-party integrations)
echo "Setting DisableZoomApps=true"
crudini --set "$ZOOM_CONFIG" General DisableZoomApps true

# =============================================================================
# NETWORK & SERVER
# =============================================================================

# Set Zoom server URL
echo "Setting conf.webserver=https://zoom.us"
crudini --set "$ZOOM_CONFIG" General conf.webserver "https://zoom.us"

# =============================================================================
# LOGGING
# =============================================================================

# Logging (only enable if requested via -l flag)
if [ "$ENABLE_LOGGING" = true ]; then
    echo "Setting enableLog=true"
    crudini --set "$ZOOM_CONFIG" General enableLog true
    echo "Setting logLevel=info"
    crudini --set "$ZOOM_CONFIG" General logLevel info
    echo -e "${YELLOW}Note: Logs will be saved to ~/.zoom/logs/${NC}"
else
    echo "Setting enableLog=false (use -l to enable)"
    crudini --set "$ZOOM_CONFIG" General enableLog false
fi

# =============================================================================
# UI & APPEARANCE
# =============================================================================

# Set geographic locale
echo "Setting GeoLocale=system"
crudini --set "$ZOOM_CONFIG" General GeoLocale system

# Mask sensitive information
echo "Setting SensitiveInfoMaskOn=true"
crudini --set "$ZOOM_CONFIG" General SensitiveInfoMaskOn true

# =============================================================================
# PERFORMANCE
# =============================================================================

# Disable CEF (Chromium Embedded Framework)
# Note: Saves RAM but disables features like whiteboard
echo "Setting disableCef=true"
crudini --set "$ZOOM_CONFIG" General disableCef true

# =============================================================================
# WAYLAND SUPPORT
# =============================================================================

# Auto-detect and configure Wayland screen sharing
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    echo "Wayland detected - enabling Wayland screen share"
    crudini --set "$ZOOM_CONFIG" General enableWaylandShare true
    crudini --set "$ZOOM_CONFIG" General xwayland false
fi

echo "----------------------------------------"
echo -e "${GREEN}Zoom configuration completed successfully!${NC}"
echo ""
echo "IMPORTANT: Please restart Zoom for changes to take effect."
echo ""

# Check if Zoom is currently running
if pgrep -x "zoom" > /dev/null; then
    echo -e "${YELLOW}Warning: Zoom is currently running.${NC}"
    echo "You may want to restart it now:"
    echo "  killall zoom && zoom &"
fi

################################################################################
# ADDITIONAL CONFIGURATION OPTIONS REFERENCE
################################################################################
#
# The following sections document all available Zoom configuration options.
# These options are compiled from multiple sources:
#
# PRIMARY SOURCES:
#   - Zoom Available Configuration Options (GitHub Gist)
#     https://gist.github.com/wallentx/4c75a2c10fd0c46f696548d9d23382d2
#     Comprehensive list of Zoom config keys for Windows, macOS, and Linux
#
#   - Zoom Meetings - ArchWiki
#     https://wiki.archlinux.org/title/Zoom_Meetings
#     Linux-specific configuration and troubleshooting
#
#   - Zoom Support - Troubleshooting log for Linux
#     https://support.zoom.com/hc/en/article?id=zm_kb&sysparm_article=KB0066626
#     Official Zoom documentation for Linux client
#
# To add any option below to the script, use:
#   crudini --set "$ZOOM_CONFIG" General <option> <value>
#
################################################################################
# ADDITIONAL VIDEO/CAMERA OPTIONS AVAILABLE
################################################################################
#
# The following options can be added to the script if needed.
# Add them using: crudini --set "$ZOOM_CONFIG" General <option> <value>
#
# VIDEO ON/OFF SETTINGS:
# ----------------------
# zDisableVideo=true               - Automatically turn off camera when joining
# zDisableSendVideo=true           - Disable sending video
# zDisableRecvVideo=true           - Disable receiving video
#
# VIDEO QUALITY:
# --------------
# zUse720PByDefault=true           - Use HD video (720p) in meetings
# captureHDCamera=true             - Capture HD camera (CURRENTLY ENABLED)
# newMeetingWithVideo=true         - Start new meetings with video (CURRENTLY ENABLED)
#
# CAMERA PREVIEW:
# ---------------
# AlwaysShowVideoPreviewDialog=true - Always show video preview when joining
#
# VIDEO APPEARANCE:
# -----------------
# EnableFaceBeauty=true            - Enable "Touch up my appearance" filter
# EnableMirrorEffect=true          - Mirror your video
# EnableAutoLightAdaption=true     - Auto adjust for low-light
# EnableLightAdaption=true         - Enable low-light adjustment setting
#
# BACKGROUND & FILTERS:
# ---------------------
# DisableVideoFilters=true         - Disable video filters feature
# DisableVirtualBkgnd=true         - Disable virtual background feature
# EnableAutoReverseVirtualBkgnd=true - Auto-reverse virtual background after meeting
#
# GALLERY VIEW:
# -------------
# Enable49Video=true               - Display up to 49 participants in Gallery View
# zHideNoVideoUser=true            - Hide non-video participants (CURRENTLY ENABLED)
# DefaultUsePortraitView=true      - Default to portrait mode on launch
#
# ADVANCED VIDEO:
# ---------------
# VideoRenderMethod=Auto           - Rendering method (Auto/Direct3D11/Direct3D9/GDI)
# EnableSpotlightSelf=true         - Show yourself as active speaker when speaking
#
# AUDIO OPTIONS:
# ---------------
#
# AUTO-JOIN & CONNECTION:
# -----------------------
# zAutoJoinVoip=true                        - Auto-join with computer audio (CURRENTLY ENABLED)
# DisableComputerAudio=true                 - Disable computer audio option entirely
# DisableAudioOverProxy=true                - Prevent audio traffic over proxies
#
# MICROPHONE SETTINGS:
# --------------------
# MuteVoipWhenJoin=true                     - Start muted when joining (CURRENTLY ENABLED)
# MuteWhenLockScreen=true                   - Auto-mute when screen locks
# AudioAutoAdjust=true                      - Automatically adjust microphone volume
# SetUseSystemDefaultMicForVOIP=true        - Use default system microphone
# SetSuppressBackgroundNoiseLevel=Auto      - Background noise suppression (Auto/Low/Medium/High)
#
# SPEAKER SETTINGS:
# -----------------
# SetUseSystemDefaultSpeakerForVOIP=true    - Use default system speakers
#
# AUDIO SHARING:
# --------------
# EnableShareAudio=true                     - Enable share computer audio option when sharing screen
#
# HID DEVICE CONTROL:
# -------------------
# EnableHIDControl=true                     - Enable HID control of USB devices (headsets, etc.)
#
# SYSTEM AUDIO:
# -------------
# system.audio.type=default                 - Specify audio system (default or ALSA on Linux)
#
################################################################################
# SCREEN SHARING OPTIONS:
################################################################################
#
# ENABLE/DISABLE SHARING:
# -----------------------
# DisableScreenShare=true                   - Prevent screen sharing (receiving still works)
# DisableDesktopShare=true                  - Remove desktop sharing option
# DisableDirectShare=true                   - Disable Zoom Rooms direct share
# DisableWhiteboard=true                    - Disable whiteboard feature
# zDisableAnnotation=true                   - Remove annotation capability
#
# SHARING OPTIMIZATION:
# ---------------------
# EnableHardwareOptimizeVideoSharing=true   - Use GPU acceleration for video sharing
# EnableShareVideo=true                     - Enable video optimization when sharing
# LegacyCaptureMode=true                    - Disable GPU acceleration
# SetScreenCaptureMode=value                - Select capture method
#
# SHARING BEHAVIOR:
# -----------------
# EnableDoNotDisturbInSharing=true          - Silence notifications when sharing (CURRENTLY ENABLED)
# zAutoFitWhenViewShare=true                - Auto-adjust viewing when others share
# zAutoFullScreenWhenViewShare=true         - Auto-fullscreen when viewing shares
#
# REMOTE CONTROL:
# ---------------
# DisableRemoteControl=true                 - Disable remote control feature (CURRENTLY ENABLED)
# DisableRemoteSupport=true                 - Disable remote support feature (CURRENTLY ENABLED)
# EnableShareClipboardWhenRemoteControl=true - Allow clipboard access during remote control
# zRemoteControllAllApp=true                - Allow controlling all applications
#
# SLIDE CONTROL:
# --------------
# DisableSlideControl=true                  - Disable slide control feature
#
# NETWORK:
# --------
# DisableSharingOverProxy=true              - Block sharing over proxies
#
################################################################################
# RECORDING OPTIONS:
################################################################################
#
# RECORDING LOCATION:
# -------------------
# RecordPath=/path/to/recordings            - Set default recording location
#
# RECORDING TYPES:
# ----------------
# zDisableLocalRecord=true                  - Disable local device recording
# zDisableCMR=true                          - Disable cloud recording
#
################################################################################
# CHAT & MESSAGING OPTIONS:
################################################################################
#
# IN-MEETING CHAT:
# ----------------
# zDisableChat=true                         - Disable in-meeting messaging
# zDisableFT=true                           - Disable file transfer in meetings
# DisableMeeting3rdPartyFileStorage=true    - Disable in-meeting 3rd party file transfer
# DisableLinkPreviewInChat=true             - Disable link previews in chat
#
# ZOOM CHAT/TEAM CHAT:
# --------------------
# MuteIMNotificationWhenInMeeting=true      - Mute chat notifications during meetings
# PlaySoundForIMMessage=true                - Audio alert for chat messages
# ShowIMMessagePreview=true                 - Allow message previews
# ShowProfilePhotosInChat=true              - Display user photos in chat
# ShowVideoMessageButton=true               - Enable video messages
# ShowVoiceMessageButton=true               - Enable voice messages
# SetMessengerDoNotDropThread=true          - Move new replies to bottom
#
################################################################################
# MEETING BEHAVIOR OPTIONS:
################################################################################
#
# JOINING/LEAVING:
# ----------------
# ConfirmWhenLeave=true                     - Confirm before exiting meeting
# FullScreenWhenJoin=true                   - Enter fullscreen automatically on join
# AlwaysShowVideoPreviewDialog=true         - Always show video preview when joining
#
# MEETING CONTROLS:
# -----------------
# alwaysShowMeetingControls=true            - Keep controls visible (CURRENTLY ENABLED)
# enableMiniWindow=false                    - Disable mini window overlay (CURRENTLY DISABLED)
#
# DISPLAY OPTIONS:
# ----------------
# zDualMonitorOn=true                       - Enable dual monitor mode
# ShowConnectedTime=true                    - Display connection duration
#
# INTERACTIVE FEATURES:
# ---------------------
# DisableMeetingReactions=true              - Disable emoji reactions in meetings
# DisableWebinarReactions=true              - Disable reactions in webinars
# DisableNonVerbalFeedback=true             - Disable feedback options (raise hand, etc.)
# DisableClosedCaptioning=true              - Disable closed captioning
# DisableManualClosedCaptioning=true        - Disable user-entered captions
# DisableQnA=true                           - Disable Q&A feature in webinars
#
# BREAKOUT ROOMS:
# ---------------
# DisableBroadcastBOMessage=true            - Disable breakout room broadcasts
#
################################################################################
# SECURITY & AUTHENTICATION OPTIONS:
################################################################################
#
# SIGN-IN REQUIREMENTS:
# ---------------------
# EnforceSignInToJoin=true                  - Require authentication before joining
# EnforceAppSignInToJoin=true               - Require app sign-in to join
# KeepSignedIn=true                         - Maintain session upon relaunching
#
# SSO CONFIGURATION:
# ------------------
# ForceSSOURL=https://sso.example.com       - Set and lock default SSO URL
# zSSOHost=https://sso.example.com          - Set default SSO URL
# zAutoSSOLogin=true                        - Default to SSO authentication
# EnableEmbedBrowserForSSO=true             - Use embedded browser for SSO
# DisableAutoLaunchSSO=true                 - Prevent auto-launching previous SSO URL
#
# LOGIN METHODS:
# --------------
# DisableLoginWithEmail=true                - Remove email login option
# NoFacebook=true                           - Remove Facebook login
# NoGoogle=true                             - Remove Google login
# NoSSO=true                                - Remove SSO login
# DisableKeepSignedInWithFacebook=true      - Require fresh Facebook login
# DisableKeepSignedInWithGoogle=true        - Require fresh Google login
# DisableKeepSignedInWithSSO=true           - Require fresh SSO login
# EnableAppleLogin=true                     - Enable Apple login
# EnableAlipayLogin=true                    - Enable Alipay login
# EnablePhoneLogin=true                     - Enable phone login
# EnableWeChatLogin=true                    - Enable WeChat login
# EnableQQLogin=true                        - Enable QQ login
#
# DOMAIN & ACCOUNT:
# -----------------
# Login_Domain=company.com                  - Specify permitted email domains
# Account=AccountID1;AccountID2             - Restrict client to specified accounts
# SetWebDomain=zoom.us                      - Configure web domain for login/joining
#
# DEVICE POLICY:
# --------------
# SetDevicePolicyToken=token                - Require internal meeting authentication
# EmbedDeviceTag=device123                  - Append device identifier to HTTP requests
#
################################################################################
# NETWORK & PROXY OPTIONS:
################################################################################
#
# PROXY CONFIGURATION:
# --------------------
# conf.webserver=https://zoom.us            - Zoom server URL (CURRENTLY ENABLED)
# ProxyServer=proxy.example.com:8080        - Set proxy server
# ProxyPAC=http://proxy.example.com/pac     - Set PAC file URL
# ProxyBypass=*.local;*.internal            - Bypass proxy for specific domains
#
# BANDWIDTH:
# ----------
# BandwidthLimitUp=1024                     - Set upload bandwidth limit (kbps)
# BandwidthLimitDown=2048                   - Set download bandwidth limit (kbps)
# IgnoreBandwidthLimits=true                - Override web restrictions
#
# NETWORK RESTRICTIONS:
# ---------------------
# DisableAudioOverProxy=true                - Prevent audio over proxies
# DisableVideoOverProxy=true                - Prevent video over proxies
# DisableDirectConnection2Web=true          - Block direct web connections
#
# SSL/TLS:
# --------
# BlockUntrustedSSLCert=true                - Block untrusted certificates
# DisableCertPin=true                       - Disable certificate pinning
#
################################################################################
# UPDATES & INSTALLATION OPTIONS:
################################################################################
#
# AUTO-UPDATE:
# ------------
# zAutoUpdate=true                          - Enable user-initiated updates (CURRENTLY DISABLED)
# AlwaysCheckLatestVersion=true             - Prompt for updates if available (CURRENTLY DISABLED)
# EnableSilentAutoUpdate=true               - Install updates silently (CURRENTLY DISABLED)
# SetUpdatingChannel=Slow                   - Control update frequency (Slow/Fast)
#
# INSTALLATION:
# -------------
# DisableDaemonInstall=true                 - Control 32-to-64-bit upgrades
# SetEnrollToken4CloudMDM=token             - Enroll in device management
#
################################################################################
# ZOOM APPS & INTEGRATIONS:
################################################################################
#
# ZOOM APPS:
# ----------
# DisableZoomApps=true                      - Hide Zoom Apps button (CURRENTLY ENABLED)
# DisableZoomAppsGuestAccess=true           - Control guest app access
#
# ZOOM ROOMS:
# -----------
# EnableStartMeetingWithRoomSystem=true     - Display room system button
#
# ZOOM PHONE:
# -----------
# EnableLaunchApp4IncomingCalls=true        - Launch app for incoming calls
# SetCommand4IncomingCalls=url              - Configure incoming call URL
# HidePhoneInComingCallWhileInMeeting=true  - Suppress call notifications in meetings
#
################################################################################
# UI & APPEARANCE OPTIONS:
################################################################################
#
# THEME & DISPLAY:
# ----------------
# useSystemTheme=true                       - Use system theme
# GeoLocale=system                          - Geographic location (CURRENTLY ENABLED)
# SensitiveInfoMaskOn=true                  - Hide sensitive information (CURRENTLY ENABLED)
# forceEnableTrayIcon=true                  - Force tray icon display
#
# SCALING:
# --------
# scaleFactor=1.5                           - UI scale factor
# autoScale=true                            - Automatic UI scaling
#
# LAYOUT:
# -------
# chatListPanelLastWidth=250                - Chat panel width
# asBarTopMargin=10                         - Top margin for bar
#
# WAYLAND:
# --------
# enableWaylandShare=true                   - Enable Wayland screen share (AUTO-DETECTED)
# xwayland=false                            - Disable XWayland (AUTO-DETECTED if on Wayland)
# enableScreenSaveGuard=true                - Screen saver integration
#
################################################################################
# GOVERNMENT/COMPLIANCE OPTIONS (Zoom for Government):
################################################################################
#
# CLOUD SWITCHING:
# ----------------
# EnableCloudSwitch=true                    - Toggle between Zoom commercial and Zoom for Gov
#
# INTERCLOUD RESTRICTIONS:
# ------------------------
# Intercloud_DisableAllFeatures=true        - Restrict to audio/video only
# Intercloud_DisableAnnotation=true         - Disable annotation
# Intercloud_DisableClosedCaptioning=true   - Disable closed captioning
# Intercloud_DisableComputerAudio=true      - Disable computer audio
# Intercloud_DisableMeetingChat=true        - Disable meeting chat
# Intercloud_DisableMeetingFileTransfer=true - Disable file transfer
# Intercloud_DisableMeetingPolls=true       - Disable polls
# Intercloud_DisableLocalRecording=true     - Disable local recording
# Intercloud_DisableRemoteControl=true      - Disable remote control
# Intercloud_DisableShareScreen=true        - Disable screen sharing
# Intercloud_DisableWhiteBoard=true         - Disable whiteboard
# Intercloud_DisableMeetingReactions=true   - Disable reactions
# OverrideEnforceSigninIntercloud=true      - Allow unauthenticated ZfG joins
#
